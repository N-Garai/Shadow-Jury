# Shadow Jury Environment Variables
# Copy this to .env and fill in values

# Mock mode: set to "1" to skip cloud dependency checks
MOCK_MODE=1

# Azure Foundry (optional - only needed for real AI calls)
# AZURE_FOUNDRY_ENDPOINT=https://your-project.eastus.azurefoundry.ai
# AZURE_FOUNDRY_API_KEY=your-api-key-here

# Azure AI Search (optional - only needed for RAG)
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_API_KEY=your-search-key-here
# AZURE_SEARCH_INDEX_NAME=shadow-jury-knowledge

# OpenAI (fallback if Foundry not available)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
